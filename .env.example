# ─── Application ──────────────────────────────────────────────────────────────
ENV=development
LOG_LEVEL=INFO

# ─── Database ─────────────────────────────────────────────────────────────────
# Development (SQLite)
DB_URL=sqlite:///data/db/ambot.db
# Production (PostgreSQL)
# DB_URL=postgresql+psycopg2://user:password@localhost:5432/xmbot

# ─── Key Vault ────────────────────────────────────────────────────────────────
# 32-byte (256-bit) hex-encoded master encryption key
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
VAULT_MASTER_KEY_HEX=change_me_generate_with_secrets_token_hex_32

# ─── Commission Settings ──────────────────────────────────────────────────────
COMMISSIONS__MONTHLY_AUM_FEE_PCT=0.01
COMMISSIONS__PERFORMANCE_FEE_PCT=0.20

# ─── Risk Defaults ────────────────────────────────────────────────────────────
RISK__DEFAULT_MAX_DAILY_LOSS_PCT=0.02
RISK__DEFAULT_MAX_OPEN_POSITIONS=5
RISK__DEFAULT_MAX_LEVERAGE=3.0
RISK__DEFAULT_MAX_PER_TRADE_RISK_PCT=0.01
RISK__DEFAULT_MAX_SYMBOL_ALLOCATION_PCT=0.20
RISK__RECONCILIATION_MISMATCH_PCT=0.02
RISK__VOLATILITY_GUARD_ATR_THRESHOLD=3.0

# ─── Web / Auth ───────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change_me_generate_with_secrets_token_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ─── PDF Output ───────────────────────────────────────────────────────────────
PDF_OUTPUT_DIR=data/statements
